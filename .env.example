# ─── MCP server ───────────────────────────────────────────────────────────────
PORT=8788
# Comma-separated allowlist for Streamable HTTP Origin validation (MCP spec MUST).
MCP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
# AES-256-GCM key (32 bytes, base64) for encrypting stored provider tokens at rest.
RS_TOKENS_ENC_KEY=
# Shared secret for verifying inbound webhook HMAC signatures (recommended). [NEEDS LIVE VERIFICATION]
WEBHOOK_SECRET=

# ─── Procore (https://developers.procore.com) ──────────────────────────────────
# [NEEDS LIVE VERIFICATION] hosts/paths — confirm against live Procore docs.
PROCORE_CLIENT_ID=
PROCORE_CLIENT_SECRET=
PROCORE_REDIRECT_URI=http://localhost:8788/oauth/procore/callback
# Production: https://login.procore.com  |  Sandbox: https://login-sandbox.procore.com
PROCORE_AUTH_BASE=https://login.procore.com
# Production: https://api.procore.com    |  Sandbox: https://sandbox.procore.com
PROCORE_API_BASE=https://api.procore.com
# Default company scope for webhooks/company-level calls.
PROCORE_COMPANY_ID=

# ─── Salesforce (https://developer.salesforce.com) ─────────────────────────────
# [NEEDS LIVE VERIFICATION] — confirm against live Salesforce docs.
SF_LOGIN_URL=https://login.salesforce.com
# JWT Bearer flow (server-to-server, background sync plane):
SF_CLIENT_ID=
SF_USERNAME=
SF_JWT_PRIVATE_KEY=
# Web-server flow (per-user agent actions):
SF_CLIENT_SECRET=
SF_REDIRECT_URI=http://localhost:8788/oauth/salesforce/callback
SF_API_VERSION=v62.0

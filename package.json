{
  "name": "procore-salesforce-mcp",
  "version": "0.1.0",
  "description": "Bidirectional Procore <-> Salesforce broker exposed as a Model Context Protocol (MCP) server",
  "type": "module",
  "main": "dist/node/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/node/index.ts",
    "start": "node dist/node/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "lint": "eslint --config lint.mjs \"src/**/*.ts\" \"test/**/*.ts\"",
    "audit": "npm audit --omit=dev || true",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.0",
    "@hono/node-server": "^1.13.7",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "agents": "^0.13.3",
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260528.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9.39.4",
    "eslint-plugin-security": "^3.0.1",
    "globals": "^17.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
